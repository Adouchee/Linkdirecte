{
  "name": "linkdirecte",
  "version": "1.0.0",
  "description": "Your first-rate SDK for working with EcoleDirecte data.",
  "author": {
    "name": "Scolup",
    "url": "https://github.com/Scolup"
  },
  "contributors": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Scolup/Linkdirecte.git"
  },
  "bugs": {
    "url": "https://github.com/Scolup/Linkdirecte/issues"
  },
  "homepage": "https://github.com/Scolup/Linkdirecte#readme",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ecoledirecte",
    "sdk",
    "wrapper",
    "api",
    "school"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "browser": "./dist/index.js",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "tsc",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "precommit": "bun run format && bun run lint && bun run test",
    "test": "bun test",
    "prepublishOnly": "bun run precommit && bun run build"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "msrcrypto": "^1.5.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "oxfmt": "^0.60.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
